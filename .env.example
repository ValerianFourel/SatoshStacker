# ── SatoshiStacker config ─────────────────────────────────────────────────
# Copy to .env and fill. NEVER commit .env. Secrets are loaded via python-dotenv
# and are never logged.

# ── Mode ───────────────────────────────────────────────────────────────────
# dry_run (paper) | testnet (Binance Spot Testnet) | live
MODE=dry_run
# live additionally REQUIRES this exact value AND --mode live on the CLI:
LIVE_TRADING_CONFIRMED=no

# ── Accumulation parameters ─────────────────────────────────────────────────
BUDGET_USDC=2000
FLOOR_PRICE=35000
N_TRANCHES=8
WEIGHTING=geometric            # linear | geometric
# deploy-by-deadline: any leftover USDC is force-DCA'd after this date (ISO8601 UTC)
DEPLOY_BY=2026-08-20T00:00:00Z
WINDOW_END=2026-09-10T00:00:00Z
MAX_DEPLOY_PER_DAY_USDC=400

# ── Binance API (SPOT ONLY, WITHDRAWALS DISABLED, IP-restricted to the VPS) ──
# Startup refuses to run live if the key reports withdrawal permission.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Spot Testnet keys (https://testnet.binance.vision):
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# ── Qwen3.6-Plus advisory (veto/shrink ONLY) — OpenAI-compatible endpoint ────
# DashScope (Alibaba Model Studio, intl):  base ../compatible-mode/v1   model qwen3.6-plus
# OpenRouter (alternative):                https://openrouter.ai/api/v1  model qwen/qwen3.6-plus
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_API_KEY=
ANALYSIS_ENABLED=true
ANALYSIS_WEB_SEARCH=false       # off by default; sends queries off-box

# ── Telegram alerts + daily summary ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── BTC watch (read-only monitor + LLM analyst + Telegram Q&A) — agent.btcwatch ─
# A SEPARATE service: public Binance data only, NO keys, NO orders. Continuously
# tracks BTC order book / volume / volatility / technicals; on an out-of-the-norm
# event (peak/bottom/spike) it auto-calls the LLM and pushes a read to Telegram.
# Reuses LLM_* + TELEGRAM_* above. The LLM may write to a sandboxed scratch dir only.
WATCH_SYMBOL=BTC/USDT              # USDT = deepest public order book
WATCH_SCAN_INTERVAL_S=15           # refresh + anomaly check cadence
WATCH_RSI_OVERBOUGHT=72            # peak test
WATCH_RSI_OVERSOLD=28              # bottom test
WATCH_VOL_Z=3.0                    # volume-spike z-score
WATCH_RET_Z=3.5                    # price-spike (1m return) z-score
WATCH_NEAR_EXTREME_PCT=0.25        # within this % of 24h high/low = peak/bottom
WATCH_IMBALANCE_THRESHOLD=0.60     # |order-book imbalance| worth flagging
WATCH_ALERT_COOLDOWN_S=1800        # min seconds between the SAME alert (anti-spam)
WATCH_ANALYST_ENABLED=true         # call the LLM on events (false = numbers-only alert)
WATCH_POLL_TELEGRAM=true           # run the inbound Q&A listener
WATCH_SCRATCH_DIR=scratch          # sandbox the analyst may write to (temp files)
WATCH_NEWS_ENABLED=true            # attach BTC headlines + Fear&Greed (keyless, off-box)
WATCH_NEWS_TTL_S=600               # cache news this long (don't refetch every scan)
WATCH_WEB_SEARCH=true              # let the analyst search the web for context (off-box)
WATCH_FETCH_ARTICLES=2             # OPEN & READ the top N results (full body, not just snippet); 0 = off
WATCH_ARTICLE_MAX_CHARS=2500       # cap of article text fed to the LLM per result
# Web-search provider order: SEARXNG_URL -> TAVILY -> SERPER -> keyless DuckDuckGo.
SEARXNG_URL=                       # self-hosted metasearch you run on your server, e.g. http://localhost:8080
TAVILY_API_KEY=                    # hosted, LLM-oriented (also returns clean content) — https://tavily.com
SERPER_API_KEY=                    # or Google via https://serper.dev
# Article extraction: `pip install trafilatura` for clean text (else a built-in fallback is used).

# ── Alt-stacker (multi-asset LLM trader: SOL/ETH/HYPE/GOLD) — agent.alts_main ─
# Separate from the BTC bots (which use MODE/SYMBOL + Binance keys above). Bearish
# SOL/ETH = accumulate base cheap; HYPE range-stable = grow USD; PAXG = tokenized GOLD
# safe-haven. The LLM has FULL decision authority INSIDE the cage (max_fraction /
# turnover caps / de-peg / bad-tick / withdrawals-disabled key). One SEQUENTIAL LLM
# call per asset; weekly per-asset technical self-tune.
# Format per asset: BASE:objective:max_fraction[:symbol_override]
#   objective = accumulate_base (most units, bearish-buy-dip)
#             | accumulate_quote (range-harvest the base into more cash)
#             | store_of_value (safe-haven accumulate, e.g. gold)
ALT_ASSETS=SOL:accumulate_base:0.4,ETH:accumulate_base:0.4,HYPE:accumulate_quote:0.3,PAXG:store_of_value:0.5
# Gold: Kraken lists PAXG/USD and XAUT/USD (both ~1oz). Swap PAXG->XAUT to use Tether Gold.
# ALT_MODE is INDEPENDENT of the BTC bots' MODE (Kraken has no testnet): dry_run | live
ALT_MODE=dry_run
# Venue: binance (SOL/ETH only — HYPE/PAXG not on Binance spot) | kraken (lists all four
# vs USD). On kraken the shared cash leg defaults to USD. Kraken has NO spot testnet, so the
# kraken path is: dry_run -> small live (no testnet rehearsal).
ALT_VENUE=kraken
ALT_QUOTE=                     # blank: USDC on binance, USD on kraken (auto). Override if needed.
ALT_STACK_USDC=1000            # the pot the alt-stacker manages
# Kraken live keys (spot trade only, withdrawals/funding DISABLED) — only for ALT_VENUE=kraken live:
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
ALT_MODEL=qwen/qwen3.5-plus-20260420       # smart model; 1 call/asset/cycle
ALT_TUNE_MODEL=qwen/qwen3.5-plus-20260420  # weekly technical-tune model
ALT_SELF_TUNE=true             # weekly per-asset backtest + Qwen technical tune
ALT_CYCLE_HOURS=4              # LLM decision cadence (a decision every 4h)
ALT_NEWS_EVERY_HOURS=8        # refresh news/Fear&Greed every 8-12h (slower than decisions; saves API)
# Risk cage (deterministic; clamps the LLM):
ALT_REBAL_BAND=0.08            # ignore target moves smaller than this fraction of pot
ALT_MIN_TRADE_USDC=10          # MIN_NOTIONAL
ALT_MAX_CYCLE_TURNOVER_USDC=400
ALT_MAX_DAILY_TURNOVER_USDC=1000
ALT_MAX_TOTAL_ALLOCATION=1.0   # sum of target fractions across all alts
ALT_MAX_PRICE_JUMP_PCT=0.35    # reject a tick deviating this far from last 4h close
NEWS_ENABLED=true              # per-asset headlines + market Fear&Greed sentiment
DECISION_PINGS=true            # Telegram ping each cycle with per-asset decisions
